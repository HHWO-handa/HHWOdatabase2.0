<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | HHWO Database</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container">
                <div class="navbar-brand">
                    <a href="/">🎵 HHWO Database</a>
                </div>
                <ul class="navbar-menu">
                    <li><a href="/">ホーム</a></li>
                    <li><a href="/scores">楽譜管理</a></li>
                    <li><a href="/instruments">楽器管理</a></li>
                    <li><a href="/protected/login">管理パネル</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container">
        <h1><%= title %></h1>

        <form method="POST" action="<%= score ? `/scores/${score.id}` : '/scores' %>" class="form">
            <div class="form-group">
                <label for="title">タイトル *</label>
                <input 
                    type="text" 
                    id="title" 
                    name="title" 
                    value="<%= score ? score.title : '' %>" 
                    required 
                    class="form-control"
                    placeholder="楽譜のタイトル"
                >
            </div>

            <div class="form-group">
                <label for="composer">作曲者</label>
                <input 
                    type="text" 
                    id="composer" 
                    name="composer" 
                    value="<%= score ? score.composer : '' %>" 
                    class="form-control"
                    placeholder="作曲者名"
                >
            </div>

            <div class="form-group">
                <label for="genre">ジャンル</label>
                <select id="genre" name="genre" class="form-control">
                    <option value="">選択してください</option>
                    <option value="クラシック" <%= score && score.genre === 'クラシック' ? 'selected' : '' %>>クラシック</option>
                    <option value="ポップス" <%= score && score.genre === 'ポップス' ? 'selected' : '' %>>ポップス</option>
                    <option value="ジャズ" <%= score && score.genre === 'ジャズ' ? 'selected' : '' %>>ジャズ</option>
                    <option value="その他" <%= score && score.genre === 'その他' ? 'selected' : '' %>>その他</option>
                </select>
            </div>

            <div class="form-group">
                <label for="difficulty">難易度</label>
                <select id="difficulty" name="difficulty" class="form-control">
                    <option value="">選択してください</option>
                    <option value="初��" <%= score && score.difficulty === '初級' ? 'selected' : '' %>>初級</option>
                    <option value="中級" <%= score && score.difficulty === '中級' ? 'selected' : '' %>>中級</option>
                    <option value="上級" <%= score && score.difficulty === '上級' ? 'selected' : '' %>>上級</option>
                </select>
            </div>

            <div class="form-group">
                <label for="description">説明</label>
                <textarea 
                    id="description" 
                    name="description" 
                    class="form-control" 
                    rows="4"
                    placeholder="楽譜の説明"
                ><%= score ? score.description : '' %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">保存</button>
                <a href="/scores" class="btn btn-secondary">キャンセル</a>
            </div>
        </form>
    </main>

    <footer>
        <p>&copy; 2026 HHWO Database. All rights reserved.</p>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>