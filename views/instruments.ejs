<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | HHWO Database</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container">
                <div class="navbar-brand">
                    <a href="/">🎵 HHWO Database</a>
                </div>
                <ul class="navbar-menu">
                    <li><a href="/">ホーム</a></li>
                    <li><a href="/scores">楽譜管理</a></li>
                    <li><a href="/instruments">楽器管理</a></li>
                    <li><a href="/protected/login">管理パネル</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container">
        <div class="page-header">
            <h1><%= title %></h1>
            <a href="/instruments/new" class="btn btn-primary">+ 新しい楽器を追加</a>
        </div>

        <% if (instruments.length === 0) { %>
            <p class="no-data">楽器がまだ登録されていません</p>
        <% } else { %>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>楽器名</th>
                        <th>種類</th>
                        <th>メーカー</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% instruments.forEach(instrument => { %>
                        <tr>
                            <td><strong><%= instrument.name %></strong></td>
                            <td><%= instrument.type || '-' %></td>
                            <td><%= instrument.manufacturer || '-' %></td>
                            <td>
                                <a href="/instruments/<%= instrument.id %>" class="btn btn-small">詳細</a>
                                <a href="/instruments/<%= instrument.id %>/edit" class="btn btn-small btn-warning">編集</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </main>

    <footer>
        <p>&copy; 2026 HHWO Database. All rights reserved.</p>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>