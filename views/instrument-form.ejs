<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | HHWO Database</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container">
                <div class="navbar-brand">
                    <a href="/">🎵 HHWO Database</a>
                </div>
                <ul class="navbar-menu">
                    <li><a href="/">ホーム</a></li>
                    <li><a href="/scores">楽譜管理</a></li>
                    <li><a href="/instruments">楽器管理</a></li>
                    <li><a href="/protected/login">管理パネル</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container">
        <h1><%= title %></h1>

        <form method="POST" action="<%= instrument ? `/instruments/${instrument.id}` : '/instruments' %>" class="form">
            <div class="form-group">
                <label for="name">楽器名 *</label>
                <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    value="<%= instrument ? instrument.name : '' %>" 
                    required 
                    class="form-control"
                    placeholder="楽器の名前"
                >
            </div>

            <div class="form-group">
                <label for="type">種類</label>
                <select id="type" name="type" class="form-control">
                    <option value="">選択してください</option>
                    <option value="弦楽器" <%= instrument && instrument.type === '弦楽器' ? 'selected' : '' %>>弦楽器</option>
                    <option value="木管楽器" <%= instrument && instrument.type === '木管楽器' ? 'selected' : '' %>>木管楽器</option>
                    <option value="金管楽器" <%= instrument && instrument.type === '金管楽器' ? 'selected' : '' %>>金管楽器</option>
                    <option value="打楽器" <%= instrument && instrument.type === '打楽器' ? 'selected' : '' %>>打楽器</option>
                    <option value="鍵盤楽器" <%= instrument && instrument.type === '鍵盤楽器' ? 'selected' : '' %>>鍵盤楽器</option>
                    <option value="その他" <%= instrument && instrument.type === 'その他' ? 'selected' : '' %>>その他</option>
                </select>
            </div>

            <div class="form-group">
                <label for="manufacturer">メーカー</label>
                <input 
                    type="text" 
                    id="manufacturer" 
                    name="manufacturer" 
                    value="<%= instrument ? instrument.manufacturer : '' %>" 
                    class="form-control"
                    placeholder="メーカー名"
                >
            </div>

            <div class="form-group">
                <label for="description">説明</label>
                <textarea 
                    id="description" 
                    name="description" 
                    class="form-control" 
                    rows="4"
                    placeholder="楽器の説明"
                ><%= instrument ? instrument.description : '' %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">保存</button>
                <a href="/instruments" class="btn btn-secondary">キャンセル</a>
            </div>
        </form>
    </main>

    <footer>
        <p>&copy; 2026 HHWO Database. All rights reserved.</p>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>