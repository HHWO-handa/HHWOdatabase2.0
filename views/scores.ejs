<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | HHWO Database</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container">
                <div class="navbar-brand">
                    <a href="/"><span role="img" aria-label="musical note emoji">🎵</span> HHWO Database</a>
                </div>
                <ul class="navbar-menu">
                    <li><a href="/">ホーム</a></li>
                    <li><a href="/scores">楽譜管理</a></li>
                    <li><a href="/instruments">楽器管理</a></li>
                    <li><a href="/protected/login">管理パネル</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container">
        <div class="page-header">
            <h1><%= title %></h1>
            <a href="/scores/new" class="btn btn-primary">+ 新しい楽譜を追加</a>
        </div>

        <% if (scores.length === 0) { %>
            <p class="no-data">楽譜がまだ登録されていません</p>
        <% } else { %>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>タイトル</th>
                        <th>作曲者</th>
                        <th>ジャンル</th>
                        <th>難易度</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% scores.forEach(score => { %>
                        <tr>
                            <td><strong><%= score.title %></strong></td>
                            <td><%= score.composer || '-' %></td>
                            <td><%= score.genre || '-' %></td>
                            <td><%= score.difficulty || '-' %></td>
                            <td>
                                <a href="/scores/<%= score.id %>" class="btn btn-small">詳細</a>
                                <a href="/scores/<%= score.id %>/edit" class="btn btn-small btn-warning">編集</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </main>

    <footer>
        <p>&copy; 2026 HHWO Database. All rights reserved.</p>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>